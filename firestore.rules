rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Settings collection rules
    match /settings/{document} {
      // Only authenticated users can read settings
      allow read: if request.auth != null;
      
      // Only authenticated users can create/update settings
      // This allows the quote number counter to be updated atomically
      allow write: if request.auth != null && 
        request.resource.data.keys().hasAll(['lastQuoteNumber', 'updatedAt']) &&
        request.resource.data.lastQuoteNumber is int &&
        request.resource.data.lastQuoteNumber > 0;
      
      // Delete not allowed for settings
      allow delete: if false;
    }
    
    // Quotes collection rules (existing rules - update as needed)
    match /quotes/{quoteId} {
      // Users can read their own quotes
      allow read: if request.auth != null && 
        request.auth.uid == resource.data.userId;
      
      // Users can create their own quotes
      allow create: if request.auth != null && 
        request.auth.uid == request.resource.data.userId;
      
      // Users can update their own quotes
      allow update: if request.auth != null && 
        request.auth.uid == resource.data.userId;
      
      // Users can delete their own quotes
      allow delete: if request.auth != null && 
        request.auth.uid == resource.data.userId;
    }
    
    // Users collection rules (if exists)
    match /users/{userId} {
      // Users can read their own profile
      allow read: if request.auth != null && 
        request.auth.uid == userId;
      
      // Users can update their own profile
      allow write: if request.auth != null && 
        request.auth.uid == userId;
      
      // Users can create their own profile
      allow create: if request.auth != null && 
        request.auth.uid == userId;
    }
  }
}
